{
  "name": "nSpec",
  "displayName": "nSpec",
  "description": "Generate and maintain structured specs (Requirements → Design → Tasks → Verify) with Codex, custom prompts, hooks, and verification for spec-driven development.",
  "version": "0.2.4",
  "publisher": "awilliams",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "keywords": [
    "spec",
    "requirements",
    "design",
    "tasks",
    "verify",
    "AI",
    "Codex",
    "spec-driven",
    "OpenSpec"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nspec/nSpec.git"
  },
  "bugs": {
    "url": "https://github.com/nspec/nSpec/issues"
  },
  "homepage": "https://github.com/nspec/nSpec#readme",
  "icon": "media/icon.png",
  "activationEvents": [
    "onCommand:nspec.open",
    "onCommand:nspec.newSpec",
    "onCommand:nspec.setupSteering",
    "onCommand:nspec.vibeToSpec",
    "onCommand:nspec.scaffoldPrompts",
    "onCommand:nspec.checkTasks",
    "onCommand:nspec.validateSetup",
    "onCommand:nspec.diagnoseCodex",
    "onCommand:nspec.probeCodexWriteTestFile",
    "onView:nspec.welcomeView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nspec.open",
        "title": "nSpec: Open Panel",
        "icon": "$(notebook)"
      },
      {
        "command": "nspec.newSpec",
        "title": "nSpec: New Spec"
      },
      {
        "command": "nspec.setupSteering",
        "title": "nSpec: Setup Steering Files"
      },
      {
        "command": "nspec.vibeToSpec",
        "title": "nSpec: Generate Spec from Conversation"
      },
      {
        "command": "nspec.scaffoldPrompts",
        "title": "nSpec: Scaffold Custom Prompts"
      },
      {
        "command": "nspec.checkTasks",
        "title": "nSpec: Check Task Completion"
      },
      {
        "command": "nspec.validateSetup",
        "title": "nSpec: Validate Setup"
      },
      {
        "command": "nspec.diagnoseCodex",
        "title": "nSpec: Diagnose Codex Models"
      },
      {
        "command": "nspec.probeCodexWriteTestFile",
        "title": "nSpec: Probe Codex Write test.md"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nspec-sidebar",
          "title": "nSpec",
          "icon": "media/icon-activity.svg"
        }
      ]
    },
    "views": {
      "nspec-sidebar": [
        {
          "id": "nspec.welcomeView",
          "name": "nSpec"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "nspec.welcomeView",
        "contents": "Create and manage structured specs — Requirements → Design → Tasks → Verify.\n[Open nSpec Panel](command:nspec.open)\n[New Spec](command:nspec.newSpec)\n[Validate Setup](command:nspec.validateSetup)\n[Diagnose Codex Models](command:nspec.diagnoseCodex)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "nspec.open",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "nspec.open"
        },
        {
          "command": "nspec.newSpec"
        },
        {
          "command": "nspec.setupSteering"
        },
        {
          "command": "nspec.vibeToSpec"
        },
        {
          "command": "nspec.scaffoldPrompts"
        },
        {
          "command": "nspec.checkTasks"
        },
        {
          "command": "nspec.validateSetup"
        },
        {
          "command": "nspec.diagnoseCodex"
        },
        {
          "command": "nspec.probeCodexWriteTestFile"
        }
      ]
    },
    "configuration": {
      "title": "nSpec",
      "properties": {
        "nspec.generationProvider": {
          "type": "string",
          "enum": [
            "codex-ui",
            "lm"
          ],
          "default": "codex-ui",
          "description": "Generation provider mode. codex-ui delegates stage file edits to Codex/ChatGPT commands. lm uses direct API generation via LMClient."
        },
        "nspec.apiKey": {
          "type": "string",
          "default": "",
          "description": "Codex API key used when generationProvider is set to lm. Prefer setting this in User Settings, or use NSPEC_API_KEY / OPENAI_API_KEY environment variables."
        },
        "nspec.apiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for Codex API requests."
        },
        "nspec.apiModel": {
          "type": "string",
          "default": "gpt-5.3-codex",
          "description": "Codex model used by nSpec generation."
        },
        "nspec.specsFolder": {
          "type": "string",
          "default": ".specs",
          "description": "Folder path (relative to workspace root) where specs are stored"
        },
        "nspec.allowedCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "npm install",
            "npm run",
            "npx"
          ],
          "description": "Shell command prefixes that are auto-approved during supervised task execution. Other commands require manual approval."
        },
        "nspec.showExamplesPrompt": {
          "type": "boolean",
          "default": true,
          "description": "When a new workspace has no .specs/ folder, offer to generate example customization files (steering, role, prompt overrides). Set to false to disable this prompt."
        }
      }
    },
    "keybindings": [
      {
        "command": "nspec.open",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run format:check && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package",
    "test": "vitest run",
    "typecheck": "tsc -p ./ --noEmit",
    "quality:check": "npm run lint:strict && npm run format:check && npm run typecheck && npm run test",
    "docs:check": "node scripts/check-docs.mjs",
    "audit:gate": "node scripts/audit-gate.mjs",
    "verify:runtime": "node scripts/verify-extension-runtime.mjs",
    "test:extension": "npm run compile && node test/run-extension-tests.js",
    "lint": "eslint src --ext .ts",
    "lint:strict": "eslint src --ext .ts --max-warnings=0",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "precompile": "npm run clean",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "mocha": "^10.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
